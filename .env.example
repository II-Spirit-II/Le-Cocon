# ════════════════════════════════════════════════════════════
# Le Cocon — Variables d'environnement
# Copier ce fichier en .env et renseigner les valeurs
# NE PAS committer .env (déjà dans .gitignore)
# ════════════════════════════════════════════════════════════

# ── PostgreSQL ─────────────────────────────────────────────
DATABASE_URL=postgresql://lecocon:lecocon_dev@localhost:5432/lecocon

# ── Auth (JWT) ─────────────────────────────────────────────
# Minimum 32 caractères. Générer avec: openssl rand -base64 48
JWT_SECRET=dev-secret-change-in-production-min-32-chars!!

# ── Assistant IA (Scaleway Generative API) ───────────────────
# "off" pour désactiver
AI_PROVIDER=scaleway

# Clé API Scaleway — générer sur console.scaleway.com > IAM > API Keys
SCALEWAY_API_KEY=your-scaleway-api-key

# ID projet Scaleway (UUID visible dans l'URL de la console)
SCALEWAY_PROJECT_ID=your-scaleway-project-id

# Optionnel : surcharger l'URL de base ou le modèle
# AI_BASE_URL=https://api.scaleway.ai/your-project-id/v1
# AI_MODEL=mistral-small-3.2-24b-instruct-2506

# ── Email (vérification) ──────────────────────────────────
# "console" (dev, affiche le code en logs) ou "scaleway" (prod, Scaleway TEM)
EMAIL_PROVIDER=console

# Requis uniquement si EMAIL_PROVIDER=scaleway
# SCALEWAY_TEM_API_KEY=your-tem-api-key
# SCALEWAY_TEM_PROJECT_ID=your-tem-project-id
# EMAIL_FROM=noreply@lecocon.app
# EMAIL_FROM_NAME=Le Cocon

# ── Stockage fichiers ────────────────────────────────────
# "local" (dev, filesystem) ou "s3" (prod, Scaleway Object Storage)
STORAGE_PROVIDER=local

# Requis uniquement si STORAGE_PROVIDER=s3
# S3_ENDPOINT=https://s3.fr-par.scw.cloud
# S3_REGION=fr-par
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET_AVATARS=lecocon-avatars
# S3_BUCKET_NEWS=lecocon-news
